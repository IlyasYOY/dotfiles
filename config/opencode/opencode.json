{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "permission": {
    "edit": {
      "*": "allow",
      ".git/**": "deny"
    },
    "read": {
      "*": "allow",
      "~/Projects/IlyasYOY/dotfiles/**": "allow",
      "~/Projects/IlyasYOY/notes-wiki/**": "allow"
    },
    "external_directory": {
      "~/Projects/**": "allow"
    },
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "pwd*": "allow",
      "which *": "allow",
      "whoami*": "allow",
      "date*": "allow",
      "uname *": "allow",
      "id *": "allow",
      "ps *": "allow",
      "df *": "allow",
      "du *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "type *": "allow",
      "true*": "allow",
      "false*": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "rm -rf /": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git tag*": "allow",
      "git remote*": "allow",
      "git stash list*": "allow",
      "git rev-parse*": "allow",
      "git rev-list*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git describe*": "allow",
      "git reflog*": "allow",
      "git shortlog*": "allow",
      "git grep*": "allow",
      "git worktree list*": "allow"
    },
    "webfetch": "ask",
    "websearch": "allow"
  },
  "command": {
    "shell-command": {
      "template": "$ARGUMENTS",
      "description": "Generate one shell command",
      "agent": "shell-command",
      "subtask": false
    }
  },
  "agent": {
    "shell-command": {
      "description": "Generate one shell command from the user's request",
      "mode": "subagent",
      "hidden": true,
      "permission": {
        "*": "deny",
        "bash": "deny",
        "edit": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "skill": "deny"
      },
      "prompt": "Convert the user's request into exactly one shell command. Return only the command text. Do not use markdown. Do not explain. Do not run tools or execute the command. The command must be safe for the user to review before pressing Enter."
    }
  }
}
